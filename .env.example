APP_ENV=development
LOG_LEVEL=INFO

# API (frontend entry point)
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*

# Nimble — web search, crawling, and scraping
NIMBLE_API_KEY=
NIMBLE_BASE_URL=https://sdk.nimbleway.com/v1
NIMBLE_TIMEOUT_SECONDS=180
NIMBLE_SEARCH_TIMEOUT_SECONDS=180
NIMBLE_COUNTRY=BR
NIMBLE_LOCALE=pt-BR
NIMBLE_SEARCH_FOCUS=news
# lite | fast | deep — fast requires NIMBLE_SEARCH_FOCUS=general (enterprise)
NIMBLE_SEARCH_DEPTH=lite
NIMBLE_OUTPUT_FORMAT=markdown

# Retrieval routing (see agents/retrieval/PLAN.md)
RETRIEVAL_RELEVANCE_MIN_FOR_ANALYSIS=0.70
RETRIEVAL_CONFIDENCE_MIN_FOR_ANALYSIS=0.70
RETRIEVAL_RELEVANCE_DISCARD_BELOW=0.50
RETRIEVAL_MAX_ANALYSIS_SIGNALS=10

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8443
CLICKHOUSE_DATABASE=latam_research
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_password_here
# CLICKHOUSE_VERIFY_TLS=true

# Document fetch (Senso + ClickHouse ingestion). Uses certifi CA bundle by default.
# DOCUMENT_FETCH_VERIFY_TLS=false

# Test database (used by integration tests only)
TEST_CLICKHOUSE_HOST=localhost
TEST_CLICKHOUSE_PORT=8443
TEST_CLICKHOUSE_DATABASE=latam_research_test
TEST_CLICKHOUSE_USER=default
TEST_CLICKHOUSE_PASSWORD=your_password_here

# OpenAI API (default LLM provider)
OPENAI_API_KEY=sk-your-key-here

# LLM provider selection (optional — defaults shown)
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o-mini

# Senso semantic memory layer
SENSO_API_KEY=your_senso_api_key_here

# x402 payment layer
WALLET_ADDRESS=0xYourWalletAddressHere
REPORT_PRICE_USD=5.00
X402_NETWORK=eip155:84532
X402_FACILITATOR_URL=https://x402.org/facilitator
